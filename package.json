{
  "name": "fontfetch-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo root for fontfetch — the CLI, the shared core library, and the future fontfetch.dev webapp.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "dev": "pnpm -r --parallel --filter=./packages/* run dev",
    "test": "pnpm -r --filter=./packages/* run test",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean && rm -rf node_modules/.cache",
    "cli": "pnpm --filter fontfetch start"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@types/fontkit": "^2.0.9",
    "@types/node": "^22.10.0",
    "@types/subset-font": "^2.3.0",
    "playwright": "^1.49.0",
    "subset-font": "^2.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "author": "Niyam Vora <niyamvora@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/niyamvora/fontfetch.git"
  },
  "homepage": "https://github.com/niyamvora/fontfetch#readme"
}
