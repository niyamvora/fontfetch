{
  "name": "fontfetch",
  "version": "0.6.0",
  "description": "Download every web font from any site into a project-ready folder — with CSS, manifest, and framework configs.",
  "type": "module",
  "bin": {
    "fontfetch": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "font",
    "fonts",
    "webfont",
    "web-font",
    "font-face",
    "scrape",
    "scraper",
    "downloader",
    "google-fonts",
    "self-host",
    "self-hosted-fonts",
    "cli",
    "nextjs",
    "tailwind"
  ],
  "author": "Niyam Vora <niyamvora@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/niyamvora/fontfetch.git"
  },
  "bugs": {
    "url": "https://github.com/niyamvora/fontfetch/issues"
  },
  "homepage": "https://github.com/niyamvora/fontfetch#readme",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright": "^1.49.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "playwright": "^1.49.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
