{
  "name": "@fontfetch/core",
  "version": "1.3.0",
  "private": true,
  "description": "Shared pipeline for fontfetch — URL → @font-face extraction, download, license classification, framework emitters, font inspection, CLS-killing fallback metrics, and DOM-driven subsetting. Consumed by the CLI and the fontfetch.dev webapp.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@capsizecss/core": "^4.1.3",
    "@capsizecss/unpack": "^4.0.0",
    "fontkit": "^2.0.4"
  },
  "peerDependencies": {
    "playwright": "^1.49.0",
    "subset-font": "^2.5.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "subset-font": {
      "optional": true
    }
  }
}
